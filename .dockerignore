# .dockerignore for Next.js standalone build
# Only necessary files are copied to Docker context

# Version control
.git
.gitignore

# IDE and editors
.idea
.vscode
*.swp
*.swo
*~

# Next.js
.next
out

# Dependencies
node_modules

# Package manager files
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.yarn

# Environment variables
.env*

# TypeScript
*.tsbuildinfo
next-env.d.ts

# Testing
coverage
.nyc_output

# Documentation
README.md
*.md

# OS files
.DS_Store
Thumbs.db

# Docker
Dockerfile*
docker-compose*
.dockerignore

# CI/CD
.github
.gitlab-ci.yml
.travis.yml

# Misc
*.log
*.pem
.vercel